///|
let d_glPointAlongPathNV : Dispatch = Dispatch::new("glPointAlongPathNV")

///|
pub fn gl_point_along_path_nv(
  path : UInt,
  startSegment : Int,
  numSegments : Int,
  distance : Float,
  x : FixedArray[Float],
  y : FixedArray[Float],
  tangentX : FixedArray[Float],
  tangentY : FixedArray[Float],
) -> Bool {
  let fp : FuncRef[
    (
      UInt,
      Int,
      Int,
      Float,
      Pointer[Float],
      Pointer[Float],
      Pointer[Float],
      Pointer[Float],
    ) -> Int,
  ] = pointer_into(d_glPointAlongPathNV.get())
  borrow_array(x, fn(x_p) {
    borrow_array(y, fn(y_p) {
      borrow_array(tangentX, fn(tangentX_p) {
        borrow_array(tangentY, fn(tangentY_p) {
          (
            fp(
              path, startSegment, numSegments, distance, x_p, y_p, tangentX_p, tangentY_p,
            ) &
            0xFF
          ) !=
          0
        })
      })
    })
  })
}

