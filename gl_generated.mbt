  "glVDPAURegisterVideoSurfaceNV",
)

///|
pub fn gl_vdpau_register_video_surface_nv(
  vdpSurface : Bytes,
  target : UInt,
  numTextureNames : Int,
  textureNames : FixedArray[UInt],
) -> Int64 {
  let fp : FuncRef[(Pointer[Byte], UInt, Int, Pointer[UInt]) -> Int64] = pointer_into(
    d_glVDPAURegisterVideoSurfaceNV.get(),
  )
  borrow_bytes(vdpSurface, fn(vdpSurface_p) {
    borrow_array(textureNames, fn(textureNames_p) {
      fp(vdpSurface_p, target, numTextureNames, textureNames_p)
    })
  })
}

