  let fp : FuncRef[(Pointer[Byte], UInt, Int, Pointer[UInt], Bool) -> Int64] = pointer_into(
    d_glVDPAURegisterVideoSurfaceWithPictureStructureNV.get(),
  )
  borrow_bytes(vdpSurface, fn(vdpSurface_p) {
    borrow_array(textureNames, fn(textureNames_p) {
      fp(
