  "glLGPUCopyImageSubDataNVX",
)

///|
pub fn gl_lgpu_copy_image_sub_data_nvx(
  sourceGpu : UInt,
  destinationGpuMask : UInt,
  srcName : UInt,
  srcTarget : UInt,
  srcLevel : Int,
  srcX : Int,
  srxY : Int,
  srcZ : Int,
  dstName : UInt,
  dstTarget : UInt,
  dstLevel : Int,
  dstX : Int,
  dstY : Int,
  dstZ : Int,
  width : Int,
  height : Int,
  depth : Int,
) -> Unit {
  let fp : FuncRef[
    (
      UInt,
      UInt,
      UInt,
      UInt,
      Int,
      Int,
      Int,
      Int,
      UInt,
      UInt,
      Int,
      Int,
      Int,
      Int,
      Int,
      Int,
      Int,
    ) -> Unit,
  ] = pointer_into(d_glLGPUCopyImageSubDataNVX.get())
  fp(
    sourceGpu, destinationGpuMask, srcName, srcTarget, srcLevel, srcX, srxY, srcZ,
    dstName, dstTarget, dstLevel, dstX, dstY, dstZ, width, height, depth,
  )
}

