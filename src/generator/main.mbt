///|
/// Binding generator: parse the Khronos GL registry and emit MoonBit dispatch
/// wrappers + C call shims for every command this pass can express. Commands
/// with unsupported shapes (pointer-to-pointer, 16-bit arrays, callbacks,
/// non-string pointer returns) are simply skipped — never miscompiled.

///|
const REGISTRY : String = "upstream/libepoxy/registry/gl.xml"

///|
const OUT_MBT : String = "src/epoxy/gl_generated.mbt"

///|
const OUT_C : String = "src/epoxy/gl_generated_stub.c"

///|
fn main {
  let commands = try parse_commands(REGISTRY) catch {
    e => {
      println("parse failed: \{e}")
      return
    }
  }
  let mbt = StringBuilder::new()
  let cc = StringBuilder::new()
  let mbt_header =
    #|// GENERATED by src/generator — do not edit by hand.
    #|// MoonBit dispatch wrappers for GL commands.
    #|
    #|
  let cc_header =
    #|// GENERATED by src/generator — do not edit by hand.
    #|#include <stdint.h>
    #|#include <string.h>
    #|#include "moonbit.h"
    #|
    #|
  mbt.write_string(mbt_header)
  cc.write_string(cc_header)
  // Build alias resolution groups from every command's `<alias>` edges, so each
  // binding can fall back to its equivalent entry-point names (epoxy resolves a
  // core call on a driver that only exports the extension form).
  let edges = []
  for c in commands {
    for target in c.aliases {
      edges.push(@aliasgroup.Edge::{ name: c.name, target, })
    }
  }
  let groups = @aliasgroup.Groups::from_edges(edges)
  let mut total = 0
  let mut emitted = 0
  let seen : Map[String, Bool] = {}
  for c in commands {
    if c.name == "" || seen.contains(c.name) {
      continue
    }
    seen[c.name] = true
    total += 1
    match c.signature() {
      Some(sig) => {
        let r = render(c, sig, groups.aliases_of(c.name))
        mbt.write_string(r.moonbit)
        cc.write_string(r.c)
        emitted += 1
      }
      None => () // unsupported shape — skipped
    }
  }
  try {
    @fs.write_string_to_file(OUT_MBT, mbt.to_string())
    @fs.write_string_to_file(OUT_C, cc.to_string())
  } catch {
    e => {
      println("write failed: \{e}")
      return
    }
  }
  println("generated \{emitted} of \{total} commands")
  println("wrote \{OUT_MBT} and \{OUT_C}")
}
