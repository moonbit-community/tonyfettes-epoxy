///|
/// Binding generator: parse the Khronos GL registry and emit MoonBit dispatch
/// wrappers + C call shims for every command the first pass supports
/// (scalar/void/string-return signatures). Pointer/array, opaque-handle, and
/// callback signatures are reported and deferred.

///|
const REGISTRY : String = "upstream/libepoxy/registry/gl.xml"

///|
const OUT_MBT : String = "src/epoxy/gl_generated.mbt"

///|
const OUT_C : String = "src/epoxy/gl_generated_stub.c"

///|
/// Cap on emitted commands for the first pass (registry order ~ GL version, so
/// this front-loads core GL). Raise/remove to widen coverage.
const MAX_EMIT : Int = 100000

///|
fn main {
  let commands = try parse_commands(REGISTRY) catch {
    e => {
      println("parse failed: \{e}")
      return
    }
  }
  let mbt = StringBuilder::new()
  let cc = StringBuilder::new()
  let mbt_header =
    #|// GENERATED by src/generator — do not edit by hand.
    #|// MoonBit dispatch wrappers for GL commands with scalar/void/string signatures.
    #|
    #|
  let cc_header =
    #|// GENERATED by src/generator — do not edit by hand.
    #|#include <stdint.h>
    #|#include <string.h>
    #|#include "moonbit.h"
    #|
    #|
  mbt.write_string(mbt_header)
  cc.write_string(cc_header)
  let mut eligible = 0
  let mut emitted = 0
  let mut ptr_param = 0
  let mut ptr_ret = 0
  let mut unknown = 0
  let mut callback = 0
  let seen : Map[String, Bool] = {}
  for c in commands {
    if c.name == "" || seen.contains(c.name) {
      continue
    }
    seen[c.name] = true
    match classify(c) {
      Ok => {
        eligible += 1
        if emitted < MAX_EMIT {
          let (m, s) = emit(c)
          mbt.write_string(m)
          cc.write_string(s)
          emitted += 1
        }
      }
      PointerParam(_) => ptr_param += 1
      PointerReturn => ptr_ret += 1
      UnknownType(_) => unknown += 1
      Callback(_) => callback += 1
    }
  }
  try {
    @fs.write_string_to_file(OUT_MBT, mbt.to_string())
    @fs.write_string_to_file(OUT_C, cc.to_string())
  } catch {
    e => {
      println("write failed: \{e}")
      return
    }
  }
  println("commands total      = \{commands.length()}")
  println("eligible (scalar)   = \{eligible}")
  println("  emitted           = \{emitted} (cap \{MAX_EMIT})")
  println("deferred:")
  println("  pointer/array arg = \{ptr_param}")
  println("  pointer return    = \{ptr_ret}")
  println("  callback arg      = \{callback}")
  println("  unknown type      = \{unknown}")
  println("wrote \{OUT_MBT} and \{OUT_C}")
}
